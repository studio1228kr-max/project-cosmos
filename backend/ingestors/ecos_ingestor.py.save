BEGIN;

ALTER TABLE raw_macro_data
    ADD COLUMN IF NOT EXISTS normalization_status TEXT NOT NULL DEFAULT 'PENDING',
    ADD COLUMN IF NOT EXISTS normalization_run_id TEXT NULL,
    ADD COLUMN IF NOT EXISTS normalization_started_at TIMESTAMPTZ NULL;

-- legacy backfill
UPDATE raw_macro_data
SET normalization_status =
    CASE
        WHEN is_normalized = TRUE AND normalize_error IS NULL THEN 'SUCCESS'
        WHEN is_normalized = TRUE AND normalize_error IS NOT NULL THEN 'SKIPPED'
        WHEN is_normalized = FALSE AND normalize_error IS NOT NULL THEN 'FAILED_RETRY'
        ELSE 'PENDING'
    END
WHERE normalization_status IS NULL
   OR normalization_status = 'PENDING';

CREATE INDEX IF NOT EXISTS idx_raw_macro_data_normalization_claim
    ON raw_macro_data (
        source,
        is_normalized,
        normalization_status,
        fetched_at
    )
    WHERE is_normalized = FALSE;

CREATE INDEX IF NOT EXISTS idx_raw_macro_data_normalization_run_id
    ON raw_macro_data (normalization_run_id)
    WHERE normalization_run_id IS NOT NULL;

CREATE INDEX IF NOT EXISTS idx_raw_macro_data_normalization_started_at
    ON raw_macro_data (normalization_started_at)
    WHERE normalization_status = 'PROCESSING';

